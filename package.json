{
  "name": "vercel-monitor",
  "displayName": "Vercel Monitor",
  "description": "Track Vercel deployment status in real-time directly inside VS Code",
  "version": "0.1.0",
  "publisher": "vercel-monitor",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "vercel",
    "deploy",
    "deployment",
    "ci",
    "build"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vercel-monitor.configure",
        "title": "Vercel Monitor: Configure API Token",
        "icon": "$(settings-gear)"
      },
      {
        "command": "vercel-monitor.openPanel",
        "title": "Vercel Monitor: Open Deployment Panel",
        "icon": "$(cloud)"
      },
      {
        "command": "vercel-monitor.refresh",
        "title": "Vercel Monitor: Refresh Deployment Status",
        "icon": "$(refresh)"
      },
      {
        "command": "vercel-monitor.selectProject",
        "title": "Vercel Monitor: Select Project",
        "icon": "$(list-selection)"
      },
      {
        "command": "vercel-monitor.clearToken",
        "title": "Vercel Monitor: Clear Saved Token",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "vercel-monitor.configure"
        },
        {
          "command": "vercel-monitor.openPanel"
        },
        {
          "command": "vercel-monitor.refresh"
        },
        {
          "command": "vercel-monitor.selectProject"
        },
        {
          "command": "vercel-monitor.clearToken"
        }
      ]
    },
    "configuration": {
      "title": "Vercel Monitor",
      "properties": {
        "vercel-monitor.pollIntervalSeconds": {
          "type": "number",
          "default": 5,
          "minimum": 3,
          "maximum": 60,
          "description": "How often (in seconds) to poll for deployment status while a build is in progress."
        },
        "vercel-monitor.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when deployments complete or fail."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
